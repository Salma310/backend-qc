// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
//  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────
model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password_hash String
  role          UserRole  @default(QC)
  phone         String?
  is_active     Boolean   @default(true)
  last_login_at DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  batches_created Batch[]          @relation("BatchCreatedBy")
  gradings        GradingResult[]
  notifications   Notification[]
}

enum UserRole {
  ADMIN
  QC
  MANAGER
}

// ─────────────────────────────────────────
// FARMER
// ─────────────────────────────────────────
model Farmer {
  farmer_code String  @unique
  id          String  @id @default(uuid())
  name        String
  phone       String?
  address     String?
  village     String?
  district    String?
  city        String?
  is_active   Boolean @default(true) // tambahan: bisa nonaktifkan petani
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lands  Land[]
  batches Batch[]
}

// ─────────────────────────────────────────
// LAND (Lahan)
// ─────────────────────────────────────────
model Land {
  id         String   @id @default(uuid())
  farmer_id  String
  land_code  String   @unique
  land_name  String?
  latitude   Float?
  longitude  Float?
  location   String?
  area_size  Float?
  fruit_type String?
  is_active  Boolean  @default(true) // tambahan
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  farmer  Farmer  @relation(fields: [farmer_id], references: [id])
  batches Batch[]
}

// ─────────────────────────────────────────
// BATCH (sebelumnya Lot)
// ─────────────────────────────────────────
model Batch {
  id             String      @id @default(uuid())
  lot_code       String      @unique // pertahankan naming lama biar tidak breaking
  farmer_id      String
  land_id        String
  fruit_type     String?
  harvest_date   DateTime?
  harvest_time   DateTime?   // tambahan: jam panen spesifik
  harvest_weight Float?
  treatment      String?     // tambahan: perlakuan pasca panen
  notes          String?
  status         BatchStatus @default(OPEN) // ganti dari fresh/graded/expired

  // Summary cache — update tiap grading baru masuk
  total_fruits   Int         @default(0)  // tambahan
  total_grade_a  Int         @default(0)  // tambahan
  total_grade_b  Int         @default(0)  // tambahan
  total_grade_c  Int         @default(0)  // tambahan
  total_reject   Int         @default(0)  // tambahan

  created_by_id  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  closed_at      DateTime?   // tambahan

  farmer      Farmer          @relation(fields: [farmer_id], references: [id])
  land        Land            @relation(fields: [land_id], references: [id])
  created_by  User?           @relation("BatchCreatedBy", fields: [created_by_id], references: [id])
  gradings    GradingResult[]
  notifications Notification[]
}

enum BatchStatus {
  OPEN
  CLOSED
  EXPIRED   // tetap ada dari model lama
}

// ─────────────────────────────────────────
// GRADING RESULT + QR (digabung)
// ─────────────────────────────────────────
model GradingResult {
  id               String        @id @default(uuid())
  batch_id         String
  grading_code     String        @unique // human-readable ID per buah

  // Hasil grading
  grade            Grade
  grading_method   GradingMethod @default(AI)
  confidence       Float?
  defect_detected  Boolean?
  expiry_prediction Int?         // estimasi hari hingga expired

  // Skor visual
  color_score      Float?
  texture_score    Float?
  defect_score     Float?
  size_score       Float?        // tambahan: ukuran buah
  weight_estimate  Float?        // tambahan: estimasi berat (gram)

  // Metadata AI
  ml_model_used    String?
  ml_model_version String?

  // Foto
  image_urls       String[]      // array URL foto

  // QR — digabung di sini
  qr_token         String        @unique
  qr_url           String?
  printed_at       DateTime?
  qr_is_active     Boolean       @default(true)

  graded_by_id     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  batch      Batch          @relation(fields: [batch_id], references: [id])
  graded_by  User?          @relation(fields: [graded_by_id], references: [id])
  qr_logs    QRAccessLog[]
  notifications Notification[]
}

enum Grade {
  A
  B
  C
  REJECT  // tambahan
}

enum GradingMethod {
  AI
  MANUAL
}

// ─────────────────────────────────────────
// QR ACCESS LOG
// ─────────────────────────────────────────
model QRAccessLog {
  id          String   @id @default(uuid())
  grading_id  String
  device_type String?
  ip_address  String?  // tambahan
  user_agent  String?  // tambahan: browser/app info
  location    String?
  accessed_at DateTime @default(now())

  grading GradingResult @relation(fields: [grading_id], references: [id])
}

// ─────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────
model Notification {
  id          String             @id @default(uuid())
  batch_id    String?
  grading_id  String?
  user_id     String?            // tambahan: target notifikasi ke user tertentu

  channel     NotifChannel
  message     String
  status      NotifStatus        @default(PENDING) // tambahan: pending state
  error_msg   String?            // tambahan: simpan error kalau gagal kirim
  retry_count Int                @default(0) // tambahan: tracking retry
  sent_at     DateTime?
  createdAt   DateTime           @default(now())

  batch   Batch?         @relation(fields: [batch_id], references: [id])
  grading GradingResult? @relation(fields: [grading_id], references: [id])
  user    User?          @relation(fields: [user_id], references: [id])
}

enum NotifChannel {
  TELEGRAM
  EMAIL
  WHATSAPP  // tambahan
}

enum NotifStatus {
  PENDING
  SENT
  FAILED
}